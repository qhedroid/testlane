{
  "name": "relay",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @relay/web dev",
    "dev:reset": "bash scripts/reset-web-dev.sh",
    "build": "pnpm --filter @relay/web build",
    "start": "pnpm --filter @relay/web start",
    "db:generate": "pnpm --filter @relay/db generate",
    "db:wait": "bash scripts/wait-for-mysql.sh",
    "db:migrate": "pnpm db:wait && pnpm --filter @relay/db migrate",
    "db:studio": "pnpm --filter @relay/db studio",
    "db:seed": "pnpm db:wait && pnpm --filter @relay/db seed",
    "db:validate-create-run": "pnpm db:wait && pnpm --filter @relay/db validate:create-run",
    "db:validate-update-case-result": "pnpm db:wait && pnpm --filter @relay/db validate:update-case-result",
    "api:validate": "pnpm db:seed && pnpm --filter @relay/web validate:api",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "drizzle-orm": "^0.30.10"
    }
  }
}
