# Copy to .env at the repository root and adjust as needed.
# Next.js loads env files from the monorepo root (see apps/web/next.config.ts).

# MySQL (matches docker-compose.yml defaults)
DATABASE_URL=mysql://relay:relay@127.0.0.1:3306/relay

# OpenSearch (local Docker; security plugin disabled for dev)
OPENSEARCH_URL=http://127.0.0.1:9200

# Next.js
# For Cloudflare Tunnel demos, set BOTH this and NEXTAUTH_URL to the public
# https://… URL (no trailing slash), then restart Next. See docs/ops/cloudflare-tunnel-local-launch.md
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NextAuth (JWT session strategy — no DB adapter tables)
NEXTAUTH_SECRET=replace-with-a-random-32-byte-value-for-local-dev
NEXTAUTH_URL=http://localhost:3000
